{
  "routes": [
    {
      "src": "/index.html",
      "status": 301,
      "headers": {
        "Location": "/sign-in"
      }
    },
    {
      "src": "/",
      "dest": "/landing.html"
    },
    {
      "src": "/contact",
      "dest": "/contact.html"
    },
    {
      "src": "/changelog",
      "dest": "/changelog.html"
    },
    {
      "src": "/terms",
      "dest": "/terms.html"
    },
    {
      "src": "/privacy",
      "dest": "/privacy.html"
    },
    {
      "src": "/sign-in",
      "status": 301,
      "headers": {
        "Location": "/app"
      }
    },
    {
      "src": "/app",
      "dest": "/index.html"
    },
    {
      "src": "/app/(.*)",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
